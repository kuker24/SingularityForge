{
  "singularityForge": {
    "profile": "minimal",
    "verifyBeforeDone": true,
    "protectSecrets": true,
    "mcpDefault": "off",
    "repomixDefault": "off",
    "hookAdapters": {
      "enabled": false,
      "active": ["noop"],
      "logDir": "~/.claude/logs"
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-dangerous-command.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-edit-skill-verify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-verify-before-done.sh"
          }
        ]
      }
    ]
  }
}
